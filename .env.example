# Environment Variables Template
# Copy this file to .env and fill in your actual values
# .env file should NEVER be committed to git

# ======================
# AI PROVIDERS
# ======================

# Claude AI (Anthropic)
CLAUDE_API_KEY=your_claude_api_key_here

# GitHub Models AI
GITHUB_TOKEN=your_github_token_here

# ======================
# AUTHENTICATION & LICENSE (TODO: Add when implementing)
# ======================

# Supabase (Recommended for auth & database)
# SUPABASE_URL=your_supabase_url_here
# SUPABASE_ANON_KEY=your_supabase_anon_key_here
# SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Firebase (Alternative)
# FIREBASE_API_KEY=your_firebase_api_key_here
# FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
# FIREBASE_PROJECT_ID=your_firebase_project_id_here

# ======================
# PAYMENT PROCESSING (TODO: Add when implementing)
# ======================

# Stripe
# STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# PayPal (Alternative)
# PAYPAL_CLIENT_ID=your_paypal_client_id_here
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# ======================
# EMAIL NOTIFICATIONS (TODO: Add when implementing)
# ======================

# SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Resend (Alternative)
# RESEND_API_KEY=your_resend_api_key_here

# ======================
# APPLICATION SETTINGS
# ======================

# Environment (development, staging, production)
NODE_ENV=development

# API Base URL (for backend API)
# API_BASE_URL=http://localhost:3000/api

# License Validation Settings
# LICENSE_CHECK_INTERVAL=86400000  # 24 hours in milliseconds
# LICENSE_GRACE_PERIOD_DAYS=7

# ======================
# DEVELOPMENT ONLY
# ======================

# Enable debug logging
DEBUG=false

# Skip license validation in development
SKIP_LICENSE_CHECK=true
